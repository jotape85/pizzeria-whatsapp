# ═══════════════════════════════════════════════════════════════════
# SUPABASE — DATABASE
# ═══════════════════════════════════════════════════════════════════
# Supabase > Project Settings > Database > Connection string

# Transaction Pooler — puerto 6543 (para la app en Vercel/produccion)
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct Connection — puerto 5432 (solo para prisma migrate, no subir a Vercel)
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.xxxx.supabase.co:5432/postgres"

# ═══════════════════════════════════════════════════════════════════
# WHATSAPP CLOUD API
# Meta Developer Console > App > WhatsApp > API Setup
# ═══════════════════════════════════════════════════════════════════
WHATSAPP_ACCESS_TOKEN="EAAxxxxxxxxxxxxxxx"
WHATSAPP_PHONE_NUMBER_ID="1234567890"
WHATSAPP_BUSINESS_ACCOUNT_ID="0987654321"

# Token que inventas tu — el mismo valor va en Meta Webhook Configuration
WHATSAPP_VERIFY_TOKEN="mi-token-secreto-2024"

# App Secret — Meta App Settings > Basic > App Secret
WHATSAPP_APP_SECRET="abc123def456"

# ═══════════════════════════════════════════════════════════════════
# APP
# ═══════════════════════════════════════════════════════════════════
# En produccion: tu URL de Vercel (ej: https://pizzeria.vercel.app)
# En desarrollo: http://localhost:3000
NEXT_PUBLIC_APP_URL="https://pizzeria-whatsapp.vercel.app"

# ═══════════════════════════════════════════════════════════════════
# STORE
# Rellena despues de ejecutar: npm run db:seed
# ═══════════════════════════════════════════════════════════════════
DEFAULT_STORE_ID=""

# ═══════════════════════════════════════════════════════════════════
# PROVEEDORES
# mock = sin integracion externa (MVP)
# revo = conectado a Revo Solo / Revo Xpress
# ═══════════════════════════════════════════════════════════════════
CATALOG_PROVIDER="mock"
ORDER_PROVIDER="mock"
PAYMENT_PROVIDER="mock"

# ═══════════════════════════════════════════════════════════════════
# REVO (dejar vacio en MVP — configurar cuando haya credenciales)
# ═══════════════════════════════════════════════════════════════════
REVO_API_BASE_URL=""
REVO_API_KEY=""
REVO_SOLO_LOCATION_ID=""
REVO_XPRESS_MERCHANT_ID=""
REVO_XPRESS_SECRET=""

# ═══════════════════════════════════════════════════════════════════
# SOLO EN LOCAL — no añadir a Vercel
# ═══════════════════════════════════════════════════════════════════
# DIRECT_URL ya esta arriba — es solo para prisma migrate local
# NGROK_URL="https://xxxx.ngrok-free.app"   # cuando uses ngrok en dev
